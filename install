#!/bin/zsh

if (( !$+commands[antibody] )); then
    brew install antibody
fi

basedir=${0:a:h}
installdir=${basedir}/installs

# git
ln -sfvn ${installdir}/git/.git* ~

# vim
ln -sfvn ${installdir}/vim/.vimrc ~

# x
ln -sfvn ${installdir}/x/.Xdefaults ~

# zsh
ln -sfvn ${installdir}/zsh/.zsh* ~

# manually install antibody plugins
antibody bundle < ${basedir}/antibody/plugins > ~/.zplugins