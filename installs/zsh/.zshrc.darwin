# Darwin specific config

alias ls='ls -G'

export JAVA_HOME=$(/usr/libexec/java_home -v 1.8)
export IDEA_JDK=$(/usr/libexec/java_home -v 1.8)
export JRE_HOME=$(/usr/libexec/java_home -v 1.8)

export TEX_PATH=/Library/TeX/Root/bin/x86_64-darwin:/Library/TeX/Root/bin/universal-darwin
export PATH="/usr/local/sbin:$TEX_PATH:$JAVA_HOME/bin:$PATH"

source '/usr/local/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/path.zsh.inc'
source '/usr/local/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/completion.zsh.inc'
export GOPATH=~/Projects/go
